<?xml version="1.0" encoding="UTF-8"?>
<!-- origin at X=0.0 Y=0.0 -->
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:sple="http://sple/bpmn/test_extensions" xmlns:xs="http://www.w3.org/2001/XMLSchema" id="Definitions_1" exporter="org.eclipse.bpmn2.modeler.core" exporterVersion="1.5.4.RC1-v20220528-0836-B1" targetNamespace="http://example.com/bpmn">
  <bpmn2:process id="Process_1" name="Order Processing with Variability" isExecutable="true">
    <bpmn2:startEvent id="StartEvent_1" name="Order Received">
      <bpmn2:outgoing>Flow_1</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:task id="Task_1" name="Validate Order">
      <bpmn2:extensionElements>
        <sple:variabilityType xsi:type="xs:anyType">mandatory</sple:variabilityType>
        <sple:include xsi:type="xs:anyType">true</sple:include>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_1</bpmn2:incoming>
      <bpmn2:outgoing>Flow_2</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_2" name="Check Credit Score">
      <bpmn2:extensionElements>
        <sple:variabilityType xsi:type="xs:anyType">optional</sple:variabilityType>
        <sple:include xsi:type="xs:anyType">false</sple:include>
        <sple:exclude xsi:type="xs:anyType">true</sple:exclude>
        <sple:bindingTime xsi:type="xs:anyType" phase="deployment-time">customer_config</sple:bindingTime>
        <sple:condition xsi:type="xs:anyType" language="expression">feature.creditCheck == true</sple:condition>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_2</bpmn2:incoming>
      <bpmn2:outgoing>Flow_3</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Gateway_1" name="Payment Method" gatewayDirection="Diverging">
      <bpmn2:extensionElements>
        <sple:variabilityType xsi:type="xs:anyType">alternative</sple:variabilityType>
        <sple:bindingTime xsi:type="xs:anyType" phase="runtime">user_selection</sple:bindingTime>
        <sple:variant xsi:type="xs:anyType" id="var_creditcard" selected="true">
                    <sple:name xsi:type="xs:anyType">Credit Card</sple:name>
                    <sple:condition xsi:type="xs:anyType">payment.method == 'creditcard'</sple:condition>
                    <sple:enabled xsi:type="xs:anyType">true</sple:enabled>
                    <sple:priority xsi:type="xs:anyType">1</sple:priority>
                </sple:variant>
        <sple:variant xsi:type="xs:anyType" id="var_paypal" selected="false">
                    <sple:name xsi:type="xs:anyType">PayPal</sple:name>
                    <sple:condition xsi:type="xs:anyType">payment.method == 'paypal'</sple:condition>
                    <sple:enabled xsi:type="xs:anyType">true</sple:enabled>
                    <sple:priority xsi:type="xs:anyType">2</sple:priority>
                </sple:variant>
        <sple:variant xsi:type="xs:anyType" id="var_banktransfer" selected="false">
                    <sple:name xsi:type="xs:anyType">Bank Transfer</sple:name>
                    <sple:condition xsi:type="xs:anyType">payment.method == 'banktransfer'</sple:condition>
                    <sple:enabled xsi:type="xs:anyType">false</sple:enabled>
                    <sple:priority xsi:type="xs:anyType">3</sple:priority>
                </sple:variant>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_3</bpmn2:incoming>
      <bpmn2:outgoing>Flow_4a</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_4b</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_4c</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:task id="Task_3a" name="Process Credit Card Payment">
      <bpmn2:extensionElements>
        <sple:variabilityType xsi:type="xs:anyType">alternative</sple:variabilityType>
        <sple:variant xsi:type="xs:anyType" id="var_payment_creditcard">
                    <sple:name xsi:type="xs:anyType">Credit Card Payment</sple:name>
                    <sple:enabled xsi:type="xs:anyType">true</sple:enabled>
                </sple:variant>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_4a</bpmn2:incoming>
      <bpmn2:outgoing>Flow_5a</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_3b" name="Process PayPal Payment">
      <bpmn2:extensionElements>
        <sple:variabilityType xsi:type="xs:anyType">alternative</sple:variabilityType>
        <sple:variant xsi:type="xs:anyType" id="var_payment_paypal">
                    <sple:name xsi:type="xs:anyType">PayPal Payment</sple:name>
                    <sple:enabled xsi:type="xs:anyType">true</sple:enabled>
                </sple:variant>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_4b</bpmn2:incoming>
      <bpmn2:outgoing>Flow_5b</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_3c" name="Process Bank Transfer">
      <bpmn2:extensionElements>
        <sple:variabilityType xsi:type="xs:anyType">alternative</sple:variabilityType>
        <sple:exclude xsi:type="xs:anyType">true</sple:exclude>
        <sple:variant xsi:type="xs:anyType" id="var_payment_bank">
                    <sple:name xsi:type="xs:anyType">Bank Transfer Payment</sple:name>
                    <sple:enabled xsi:type="xs:anyType">false</sple:enabled>
                </sple:variant>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_4c</bpmn2:incoming>
      <bpmn2:outgoing>Flow_5c</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Gateway_2" gatewayDirection="Converging">
      <bpmn2:incoming>Flow_5a</bpmn2:incoming>
      <bpmn2:incoming>Flow_5b</bpmn2:incoming>
      <bpmn2:incoming>Flow_5c</bpmn2:incoming>
      <bpmn2:outgoing>Flow_6</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:task id="Task_4" name="Send Email Notification">
      <bpmn2:extensionElements>
        <sple:variabilityType xsi:type="xs:anyType">or</sple:variabilityType>
        <sple:include xsi:type="xs:anyType">false</sple:include>
        <sple:bindingTime xsi:type="xs:anyType" phase="deployment-time">notification_config</sple:bindingTime>
        <sple:condition xsi:type="xs:anyType" language="expression">config.emailNotification == true || config.smsNotification == true</sple:condition>
        <sple:variant xsi:type="xs:anyType" id="var_email" selected="false">
                    <sple:name xsi:type="xs:anyType">Email Notification</sple:name>
                    <sple:condition xsi:type="xs:anyType">notification.email == true</sple:condition>
                    <sple:enabled xsi:type="xs:anyType">false</sple:enabled>
                </sple:variant>
        <sple:variant xsi:type="xs:anyType" id="var_sms" selected="false">
                    <sple:name xsi:type="xs:anyType">SMS Notification</sple:name>
                    <sple:condition xsi:type="xs:anyType">notification.sms == true</sple:condition>
                    <sple:enabled xsi:type="xs:anyType">false</sple:enabled>
                </sple:variant>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_6</bpmn2:incoming>
      <bpmn2:outgoing>Flow_7</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:endEvent id="EndEvent_1" name="Order Processed">
      <bpmn2:incoming>Flow_7</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1"/>
    <bpmn2:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2"/>
    <bpmn2:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Gateway_1"/>
    <bpmn2:sequenceFlow id="Flow_4a" name="Credit Card" sourceRef="Gateway_1" targetRef="Task_3a"/>
    <bpmn2:sequenceFlow id="Flow_4b" name="PayPal" sourceRef="Gateway_1" targetRef="Task_3b"/>
    <bpmn2:sequenceFlow id="Flow_4c" name="Bank Transfer" sourceRef="Gateway_1" targetRef="Task_3c"/>
    <bpmn2:sequenceFlow id="Flow_5a" sourceRef="Task_3a" targetRef="Gateway_2"/>
    <bpmn2:sequenceFlow id="Flow_5b" sourceRef="Task_3b" targetRef="Gateway_2"/>
    <bpmn2:sequenceFlow id="Flow_5c" sourceRef="Task_3c" targetRef="Gateway_2"/>
    <bpmn2:sequenceFlow id="Flow_6" sourceRef="Gateway_2" targetRef="Task_4"/>
    <bpmn2:sequenceFlow id="Flow_7" sourceRef="Task_4" targetRef="EndEvent_1"/>
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_Process_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_1" bpmnElement="StartEvent_1">
